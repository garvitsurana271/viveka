# Copy to .env and fill in. With NO keys, the engine runs in OFFLINE mode
# (canned-but-faithful reasoning for the demo samples) — $0, never fails.

# --- Live engine (Gemma 4, free, ~unlimited RPD) ---
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Model id. Gemma 4 (open, free, high daily quota). Alternatives:
#   gemma-4-31b-it  (default — best reasoning)
#   gemma-4-4b-it   (lighter/faster)
#   gemini-2.5-flash (Gemini, lower free quota)
VIVEKA_GEMINI_MODEL=gemma-4-31b-it

# --- Optional: real fact-check retrieval ---
# Free Google Fact Check Tools API key (Google Cloud console). Without it,
# retrieval falls back to keyless Wikipedia — the engine still runs.
GOOGLE_FACTCHECK_API_KEY=

# --- Optional overrides ---
# VIVEKA_OFFLINE=1          # force offline/canned mode even if a key is set
# VIVEKA_LLM_PROVIDER=gemini  # gemini (default) | claude | groq
